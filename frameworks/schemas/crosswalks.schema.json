{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-security-architect/schemas/crosswalks.schema.json",
  "title": "Crosswalks Index",
  "type": "object",
  "required": ["version", "groups"],
  "properties": {
    "$comment": { "type": "string" },
    "version": { "type": "string" },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["objective", "controls"],
        "additionalProperties": false,
        "properties": {
          "objective": { "type": "string" },
          "domain": { "type": "string" },
          "controls": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["framework_id", "control_id"],
              "additionalProperties": false,
              "properties": {
                "framework_id": { "type": "string" },
                "control_id": { "type": "string" }
              }
            }
          }
        }
      }
    }
  },
  "additionalProperties": false
}
