# ── AI Provider (ADR-0001) ─────────────────────────────────────────────
AI_PROVIDER=azure-openai                # azure-openai | openai
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=                   # local dev only; Managed Identity in Azure
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21
# Fallback provider if no Azure subscription yet:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Database (ADR-0002) ────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/dev.db
# Postgres profile: postgresql+psycopg://app:app@postgres:5432/app

# ── Auth (ADR-0003) ────────────────────────────────────────────────────
AUTH_PROVIDER=mock                      # mock | entra (Chunk 11)
MOCK_AUTH_SECRET=change-me-dev-only     # signs the dev identity cookie
# Entra (Chunk 11):
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=

# ── Services ───────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
MCP_SERVER_URL=http://localhost:8100/mcp
FRONTEND_URL=http://localhost:3000

# ── Guardrails (Chunk 4) ───────────────────────────────────────────────
MAX_INPUT_CHARS=8000
TOKEN_BUDGET_PER_CONVERSATION=200000
TOOL_CALL_AUDIT_LOG=true

# ── Environment ────────────────────────────────────────────────────────
APP_ENV=development                     # development | production
